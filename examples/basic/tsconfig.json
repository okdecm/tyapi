{
	"compilerOptions": {
		"strict": true,
		"target": "ESNext",
		"types": [
			"node"
		],
		"lib": [
			"ESNext",
			"DOM",
			"DOM.Iterable"
		],
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"noImplicitAny": true,
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,
		"noEmit": true,
		
		"esModuleInterop": true,
			
		"module": "NodeNext",
		"moduleResolution": "NodeNext",

		"baseUrl": "./src",
		"rootDir": "./src",
		"outDir": "./dist"
	},
	"include": [
		"src"
	]
}
